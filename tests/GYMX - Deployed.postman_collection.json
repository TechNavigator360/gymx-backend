      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"T01 - User registration succeeds or already exists\", function () {\r",
              "    pm.expect([201, 400]).to.include(pm.response.code);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 201) {\r",
              "\r",
              "    pm.test(\"T01 - Response is JSON\", function () {\r",
              "        pm.response.to.be.json;\r",
              "    });\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.test(\"T01 - User object returned\", function () {\r",
              "        pm.expect(response.user).to.exist;\r",
              "        pm.expect(response.user.email).to.eql(\r",
              "            pm.collectionVariables.get(\"userAEmail\")\r",
              "        );\r",
              "    });\r",
              "}\r",
              "\r",
              "if (pm.response.code === 400) {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.test(\"T01 - Duplicate registration handled safely\", function () {\r",
              "        pm.expect(response.message).to.exist;\r",
              "    });\r",
              "}"
            ],
